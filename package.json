{
  "name": "lofi-yeti-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "indexer": "bun run src/indexer.ts",
    "api": "bun run src/api.ts",
    "reset": "rm -f yetis.db yetis.db-* && echo 'db reset'",
    "backfill-status": "bun run -e \"import { totalCount, allTraitTypes } from './src/db'; console.log('nfts:', totalCount()); console.log('traits:', allTraitTypes());\""
  },
  "dependencies": {
    "@mysten/sui": "^1.18.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.2"
  }
}
